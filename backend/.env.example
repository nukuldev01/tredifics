# Local development env. For production see .env.production.example.

SECRET_KEY=dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty to use SQLite locally.
DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Razorpay TEST keys
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# Console backend so dev OTP / order emails print to terminal
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Tredific <noreply@tredific.com>

# Sentry — leave blank for dev
SENTRY_DSN=
